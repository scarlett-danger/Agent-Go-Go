# --- Slack ------------------------------------------------------------------

# User token (xoxp-) from your Slack app's OAuth & Permissions page.

# User Token Scopes needed:

#   chat:write, channels:history, groups:history, im:history, mpim:history,

#   users:read

SLACK_USER_TOKEN=xoxp-...

# Signing secret from your Slack app's Basic Information page.

SLACK_SIGNING_SECRET=...

# Optional: explicit user ID (loop guard). Empty = auto-detect via auth.test.

SLACK_USER_ID=

# Optional: comma-separated keywords that must appear in a message (case-insensitive)
# before the bot responds. Empty = respond to every message. AppMentions always
# get a response regardless of this setting.
# Example: TRIGGER_KEYWORDS=agent go-go,go-go

TRIGGER_KEYWORDS=

# --- OpenRouter -------------------------------------------------------------

# Single API key from https://openrouter.ai/keys

# Configure Langfuse integration in the OpenRouter dashboard, NOT here —

# the bot just sends metadata in each request and OpenRouter forwards traces.

OPENROUTER_API_KEY=sk-or-v1-...

OPENROUTER_URL=https://openrouter.ai/api/v1

# Judge / summarizer model. Smallest of the three free models for speed.

JUDGE_MODEL=openai/gpt-oss-20b:free

# --- Memory & context window -----------------------------------------------

DB_PATH=./data/bot.db

MEMORY_MAX_TURNS=20

MEMORY_SUMMARIZE_AT=30

MEMORY_SUMMARIZE_FOLD=10

# --- Config files -----------------------------------------------------------

ROUTING_CONFIG=./config/routing.yaml

MCP_CONFIG=./config/mcp.yaml

# --- Temporal ---------------------------------------------------------------

TEMPORAL_HOST_PORT=localhost:7233

TEMPORAL_NAMESPACE=default

TEMPORAL_TASK_QUEUE=Agent-Go-Go-queue

# --- HTTP -------------------------------------------------------------------

SERVER_PORT=8080

# --- Sentry (non-LLM errors only — LLM observability is in Langfuse) -------

# Leave SENTRY_DSN empty to disable.

SENTRY_DSN=

SENTRY_ENVIRONMENT=development

SENTRY_RELEASE=dev

# 0.0–1.0. With Langfuse handling LLM traces, you can keep Sentry traces low

# (0.2 = 20%) since it's only catching infra-level events.

SENTRY_TRACES_SAMPLE_RATE=0.2
